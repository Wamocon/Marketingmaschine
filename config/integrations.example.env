# Copy to your deployment secret manager. Do not commit real values.

DATABASE_URL=postgresql://marketing:marketing@postgres:5432/marketing_machine
REDIS_URL=redis://redis:6379/0

LOCAL_OPENAI_BASE_URL=http://qwen-vllm:8000/v1
LOCAL_OPENAI_API_KEY=local-dev-key
LOCAL_MODEL_NAME=Qwen/Qwen3.6-35B-A3B

CLOUD_OPENAI_BASE_URL=
CLOUD_OPENAI_API_KEY=
CLOUD_MODEL_NAME=

KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_API_KEY=
KIMI_MODEL_NAME=

N8N_BASE_URL=http://n8n:5678
MARKETING_MACHINE_N8N_WORKFLOWS_VERIFIED=false

# Production human operations require two distinct Docker secrets.
MARKETING_MACHINE_MUTATION_TOKEN_FILE=/run/secrets/marketing_mutation_token
MARKETING_MACHINE_MUTATION_AUTH_MODE=required
MARKETING_MACHINE_ACTOR_AUTH_MODE=required
MARKETING_MACHINE_EDGE_ATTESTATION_FILE=/run/secrets/marketing_edge_attestation
POSTIZ_BASE_URL=http://postiz:5000
POSTIZ_API_KEY=
POSTIZ_CREATE_DRAFT_PATH=/api/public/v1/posts
POSTIZ_LIST_POSTS_PATH=/api/public/v1/posts
POSTIZ_CONTRACT_VERIFIED=false
POSTIZ_LINKEDIN_INTEGRATION_ID=
POSTIZ_LINKEDIN_PROVIDER_TYPE=linkedin
POSTIZ_INSTAGRAM_INTEGRATION_ID=
POSTIZ_INSTAGRAM_PROVIDER_TYPE=instagram
POSTIZ_MEDIA_ORIGIN=
METRICOOL_API_KEY=

MAUTIC_BASE_URL=http://mautic
MAUTIC_CLIENT_ID=
MAUTIC_CLIENT_SECRET=
MAUTIC_API_KEY=
MAUTIC_CREATE_CONTACT_PATH=/api/contacts/new
MAUTIC_CONTRACT_VERIFIED=false

TWENTY_BASE_URL=http://twenty:3000
TWENTY_API_KEY=
TWENTY_CREATE_CONTACT_PATH=/rest/people
TWENTY_CONTRACT_VERIFIED=false
HUBSPOT_PRIVATE_APP_TOKEN=

COMFYUI_BASE_URL=http://comfyui:8188

# Trend Studio / public-source research
# Use at least one search source for live 10-day trend discovery.
SEARXNG_BASE_URL=http://searxng:8080
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2
