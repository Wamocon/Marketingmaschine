N8N_MIGRATION_SOURCE_DIR=/home/wamocon/lokal-ai/data/n8n-files/wamocon-marketing-machine/backups/production-hardening/replace-with-final-stamp/entities-with-executions
N8N_MIGRATION_WORK_DIR=/home/wamocon/lokal-ai/data/n8n-files/wamocon-marketing-machine/migration-work/replace-with-final-stamp
# Required values intentionally stay empty so `docker compose config` fails
# until the operator supplies the canonical hostname and protected HTTPS routes.
# Use a hostname without scheme or path for N8N_CANONICAL_HOST. 0.0.0.0 is only
# the separate N8N_LISTEN_ADDRESS inside Compose and is invalid here. Workflow
# secrets stay in encrypted n8n credentials.
N8N_CANONICAL_HOST=
N8N_WEBHOOK_URL=
N8N_EDITOR_BASE_URL=
