{
  "id": "Psaft2cYujD42MAs",
  "name": "WAMOCON Marketing - Integration Health",
  "active": true,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 6
            }
          ]
        }
      },
      "id": "health-schedule",
      "name": "Every 6 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "http://wmc-marketing-agent:8080/integrations/status",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "check-status",
      "name": "Check Agent Integrations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [520, 300],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000,
      "onError": "continueRegularOutput",
      "credentials": {
        "httpHeaderAuth": {
          "name": "WAMOCON Agent Access Token"
        }
      }
    }
  ],
  "connections": {
    "Every 6 Hours": {
      "main": [[{"node": "Check Agent Integrations", "type": "main", "index": 0}]]
    }
  },
  "settings": {"executionOrder": "v1"}
}
