{
  "id": "WMCAnalytics14d1",
  "name": "WAMOCON 14d Due Discovery (Read Only)",
  "active": true,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "30 7 * * *"
            }
          ]
        }
      },
      "id": "weekly-14d-schedule",
      "name": "Daily 07:30 discovery",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "http://wmc-marketing-agent:8080/workflows/analytics/due?review_window=14d",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "call-agent-14d",
      "name": "Discover content due for 14d review (read only)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [520, 300],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000,
      "onError": "stopWorkflow",
      "credentials": {
        "httpHeaderAuth": {
          "name": "WAMOCON Agent Access Token"
        }
      }
    }
  ],
  "connections": {
    "Daily 07:30 discovery": {
      "main": [
        [
          {
            "node": "Discover content due for 14d review (read only)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
