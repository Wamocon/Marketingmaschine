# Copy to deploy/marketing-agent.generated.env on the host. Do not commit real values.

CLOUD_OPENAI_BASE_URL=
CLOUD_OPENAI_API_KEY=
CLOUD_MODEL_NAME=

COMFYUI_BASE_URL=
OLLAMA_BASE_URL=
LOCAL_OPENAI_BASE_URL=
LOCAL_OPENAI_API_KEY=ollama
LOCAL_OPENAI_MODEL_NAME=
LOCAL_MODEL_NAME=qwen3.6:35b
MARKETING_MACHINE_AI_ENABLED=true
MARKETING_MACHINE_ALLOW_CLOUD_FALLBACK=false
MARKETING_MACHINE_MODEL_TIMEOUT_SECONDS=90
MARKETING_MACHINE_MODEL_RETRIES=1
# Fail closed for direct manual/API intake: every request must explicitly be
# evergreen or current_trend. Evergreen rejects current/latest/trending claims;
# current_trend always requires a currently eligible stored trend, independent
# of this switch. false is migration-only and defaults a missing mode to
# evergreen. MARKETING_MACHINE_REQUIRE_VERIFIED_TRENDS remains a deprecated
# compatibility alias; do not configure both names with different values.
MARKETING_MACHINE_REQUIRE_EXPLICIT_CONTENT_MODE=true
MARKETING_MACHINE_N8N_WORKFLOWS_VERIFIED=false

# IANA timezone used for campaign dates and ISO-week planning. Keep the
# approved Berlin business calendar unless the operating company changes it.
MARKETING_MACHINE_BUSINESS_TIMEZONE=Europe/Berlin

# The API accepts only loopback, its Docker service name, and the exact
# comma-separated hostnames/IP addresses listed here. Wildcards, schemes,
# paths, and ports are rejected. The LAN edge independently requires this
# value before it starts; use the hostname(s) and/or IP address(es) present in
# the TLS certificate, for example: marketing.internal,192.0.2.10
MARKETING_MACHINE_ALLOWED_HOSTS=
MARKETING_MACHINE_ALLOWED_CLIENT_CIDRS=
MARKETING_COMFYUI_UPSTREAM=

# Interactive API documentation is unavailable in production and candidate
# modes. It is exposed only when INSTANCE_MODE is development or test.
MARKETING_MACHINE_ENABLE_TECHNICAL_DOCS=false

# Required for every POST/PUT/PATCH/DELETE request. Generate a high-entropy
# secret and send it as X-WAMOCON-Mutation-Token. For a loopback-only local
# development process, the explicit unsafe mode is: local-dev-disabled.
MARKETING_MACHINE_MUTATION_TOKEN=
MARKETING_MACHINE_MUTATION_TOKEN_FILE=/run/secrets/marketing_mutation_token
MARKETING_MACHINE_MUTATION_AUTH_MODE=required

# Production human actions require a named Basic-auth account attested by the
# edge proxy. This must be a second Docker secret, never the mutation token.
MARKETING_MACHINE_ACTOR_AUTH_MODE=required
MARKETING_MACHINE_EDGE_ATTESTATION=
MARKETING_MACHINE_EDGE_ATTESTATION_FILE=/run/secrets/marketing_edge_attestation

# Public trend research. SearxNG is the no-key default; Firecrawl adds
# search-and-scrape results when a key is configured.
SEARXNG_BASE_URL=http://ux-searxng:8080
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2
FIRECRAWL_API_KEY=
FIRECRAWL_ALLOW_UNAUTHENTICATED_SELF_HOSTED=false
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
REDDIT_BEARER_TOKEN=
REDDIT_USER_AGENT=wamocon-marketing-machine/0.2
TIKTOK_RESEARCH_CLIENT_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_API_KEY=
KIMI_MODEL_NAME=

# External writes stay disabled unless explicitly enabled. The paths below are
# the upstream routes; do not add tokens until the tenant-specific payload has
# passed an approved staging test. Postiz uses a raw Authorization API key;
# Twenty and Mautic use Bearer tokens.
MARKETING_MACHINE_ENABLE_EXTERNAL_WRITES=false
POSTIZ_CREATE_DRAFT_PATH=/api/public/v1/posts
POSTIZ_LIST_POSTS_PATH=/api/public/v1/posts
POSTIZ_API_KEY=
POSTIZ_CONTRACT_VERIFIED=false
POSTIZ_LINKEDIN_INTEGRATION_ID=
POSTIZ_LINKEDIN_PROVIDER_TYPE=linkedin
POSTIZ_INSTAGRAM_INTEGRATION_ID=
POSTIZ_INSTAGRAM_PROVIDER_TYPE=instagram
POSTIZ_MEDIA_ORIGIN=
TWENTY_CREATE_CONTACT_PATH=/rest/people
TWENTY_API_KEY=
TWENTY_CONTRACT_VERIFIED=false
MAUTIC_CREATE_CONTACT_PATH=/api/contacts/new
MAUTIC_API_KEY=
MAUTIC_CONTRACT_VERIFIED=false
